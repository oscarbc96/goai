#!/bin/sh

# ─────────────────────────────────────────────────────────────────────
# Commit-msg hook for goai public repo
# Block AI-authored metadata in commit messages
# ─────────────────────────────────────────────────────────────────────

AI_NAMES='Claude|Anthropic|OpenAI|Copilot|GPT|Gemini|Cursor|Devin|Windsurf|Codeium|CodeWhisperer|Tabnine|Amazon Q'
EM_DASH=$(printf '\xe2\x80\x94')
BLOCKED="Co-Authored-By:|(Generated|Assisted|Written|Created|Produced|Built) (by|with) ($AI_NAMES)|AI[- ]generated|[Cc]laude[ -][Cc]ode|$EM_DASH"

if grep -iEq "$BLOCKED" "$1"; then
  echo "commit-msg: message contains AI metadata."
  echo ""
  grep -inE "$BLOCKED" "$1" | head -5
  echo ""
  echo "Remove these lines from your commit message."
  exit 1
fi

exit 0
