#!/bin/sh

# ─────────────────────────────────────────────────────────────────────
# Pre-commit hook for goai public repo
# 1. Block banned files (private/internal content)
# 2. Block banned references (private project names)
# 3. Block AI-authored metadata in staged files
# ─────────────────────────────────────────────────────────────────────

# ── Guard: block .local email ──────────────────────────────────────
EMAIL=$(git config user.email)
if echo "$EMAIL" | grep -q '\.local$'; then
  echo "pre-commit: git user.email is '$EMAIL' (.local)"
  echo "Set a public email before committing to goai."
  exit 1
fi

# ── Block banned files ─────────────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

BANNED_FILES=$(echo "$STAGED" | grep -E '(^|/)SPEC\.md$|(^|/)CLAUDE\.md$|/testdata/|coverage[0-9]*_test\.go|coverage_[a-z]+_test\.go|cov[0-9]*_test\.go|e2e[_a-z]*_test\.go|_e2e_[a-z]*_test\.go|teatest[_a-z]*_test\.go|_pty_test\.go|pty_test\.go|_phase[0-9]*_test\.go')
if [ -n "$BANNED_FILES" ]; then
  echo "pre-commit: banned files detected in staging area:"
  echo ""
  echo "$BANNED_FILES"
  echo ""
  echo "These files must not exist in the goai public repo."
  exit 1
fi

# ── Block "Ported from" references ─────────────────────────────────
PORTED=$(git diff --cached --diff-filter=ACMR -U0 -- . | grep -iE '^\+.*[Pp]orted from [Vv]ercel')
if [ -n "$PORTED" ]; then
  echo "pre-commit: staged changes contain 'Ported from Vercel' references."
  echo ""
  echo "$PORTED" | head -5
  echo ""
  echo "Remove these before committing."
  exit 1
fi

# ── Block banned references ────────────────────────────────────────
# Exclude README.md (marketing for zendev.sh is ok)
EXCLUDE=':(exclude)README.md :(exclude).git/hooks/*'

REFS=$(git diff --cached --diff-filter=ACMR -U0 -- . $EXCLUDE | grep -iE '^\+.*(zenbot|zendev|vibeflow|claude)')
if [ -n "$REFS" ]; then
  echo "pre-commit: staged changes contain banned references (zenbot/zendev/vibeflow/claude)."
  echo ""
  echo "$REFS" | head -10
  echo ""
  echo "Remove these before committing."
  exit 1
fi

# ── Block AI-authored metadata ─────────────────────────────────────
AI_NAMES='Claude|Anthropic|OpenAI|Copilot|GPT|Gemini|Cursor|Devin|Windsurf|Codeium|CodeWhisperer|Tabnine|Amazon Q'
EM_DASH=$(printf '\xe2\x80\x94')
BLOCKED="Co-Authored-By:|(Generated|Assisted|Written|Created|Produced|Built) (by|with) ($AI_NAMES)|AI[- ]generated|[Cc]laude[ -][Cc]ode|$EM_DASH"

# Files that legitimately reference AI tools
EXCLUDE_AI=':(exclude).git/hooks/* :(exclude)AGENTS.md'

DIFF=$(git diff --cached --diff-filter=ACMR -U0 -- . $EXCLUDE_AI)

if echo "$DIFF" | grep -iEq "^\+.*($BLOCKED)"; then
  echo "pre-commit: staged changes contain AI metadata."
  echo ""
  echo "$DIFF" | grep -inE "^\+.*($BLOCKED)" | head -10
  echo ""
  echo "Remove these before committing."
  exit 1
fi

exit 0
